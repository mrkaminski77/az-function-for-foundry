{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "STORAGE_ACCOUNT_URL": "https://<storage-account-name>.blob.core.windows.net",
    "TABLE_ACCOUNT_URL": "https://<storage-account-name>.table.core.windows.net",
    "KEY_VAULT_URL": "https://<key-vault-name>.vault.azure.net/",
    "KEY_VAULT_SECRET_NAME": "",
    "EWS_SEND_RESULTS_ENABLED": "false",
    "RESULTS_SENDER_PROVIDER": "ews",
    "GRAPH_SEND_RESULTS_ENABLED": "false",
    "EWS_TENANT_ID": "<entra-tenant-id>",
    "EWS_SENDER_EMAIL": "<shared-mailbox-or-sender@contoso.com>",
    "EWS_RECIPIENTS": "recipient1@contoso.com,recipient2@contoso.com",
    "EWS_CLIENT_ID_SECRET_NAME": "ews-app-client-id",
    "EWS_CLIENT_SECRET_SECRET_NAME": "ews-app-client-secret",
    "EWS_SERVER": "outlook.office365.com",
    "EWS_ACCESS_TYPE": "IMPERSONATION",
    "EWS_SUBJECT_PREFIX": "[OCDS]",
    "AZURE_AI_FOUNDRY_ENDPOINT": "https://<foundry-resource-name>.services.ai.azure.com",
    "AZURE_AI_FOUNDRY_PROJECT": "<project-name>",
    "AZURE_AI_FOUNDRY_CLASSIFIER_AGENT": "<agent-id>",
    "AUSTENDER_OCDS_URL": "https://api.tenders.gov.au/ocds/releases",
    "AUSTENDER_CHECK_SCHEDULE": "0 0 */6 * * *",
    "ENTRA_TEST_SCOPE": "https://graph.microsoft.com/.default",
    "GRAPH_API_URL": "https://graph.microsoft.com/v1.0/"
  }
}
